{
  "name": "quizmaker-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:smoke": "node --test tests/smoke.test.mjs",
    "audit:production": "npm audit --omit=dev",
    "browserslist:update": "npx update-browserslist-db@latest",
    "preview": "vite preview",
    "generate-sitemap": "VITE_API_BASE_URL=${VITE_API_BASE_URL:-http://localhost:8080/api} node scripts/generate-sitemap.mjs",
    "prerender": "VITE_API_BASE_URL=${VITE_API_BASE_URL:-http://localhost:8080/api} node scripts/prerender.mjs",
    "build:prerender": "VITE_API_BASE_URL=${VITE_API_BASE_URL:-http://localhost:8080/api} npm run build && VITE_API_BASE_URL=${VITE_API_BASE_URL:-http://localhost:8080/api} npm run generate-sitemap && VITE_API_BASE_URL=${VITE_API_BASE_URL:-http://localhost:8080/api} npm run prerender"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@tailwindcss/forms": "^0.5.10",
    "@tanstack/react-query": "^5.20.3",
    "@types/dompurify": "^3.0.5",
    "axios": "^1.10.0",
    "dompurify": "^3.3.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^6.23.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.5.2",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "@vitest/coverage-v8": "^4.1.9",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "playwright": "^1.57.0",
    "postcss": "^8.5.4",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.5",
    "vitest": "^4.1.9"
  }
}
